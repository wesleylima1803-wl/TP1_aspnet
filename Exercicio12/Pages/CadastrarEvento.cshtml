@page
@model Exercicio12.Pages.CadastrarEventoModel
@{
    ViewData["Title"] = "Cadastrar Evento";
}

<div class="container mt-4">
    <h2>Agendar Novo Evento</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div class="form-group mb-3">
                    <label asp-for="NovoEvento.Titulo" class="control-label">Título do Evento:</label>
                    <input asp-for="NovoEvento.Titulo" class="form-control" required placeholder="Ex: Workshop de C#" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NovoEvento.Data" class="control-label">Data e Hora:</label>
                    <input asp-for="NovoEvento.Data" type="datetime-local" class="form-control" required />
                </div>

                <div class="form-group mb-4">
                    <label asp-for="NovoEvento.Local" class="control-label">Local:</label>
                    <input asp-for="NovoEvento.Local" class="form-control" required placeholder="Ex: Auditório Principal" />
                </div>

                <button type="submit" class="btn btn-primary">Salvar Evento</button>
            </form>
        </div>
    </div>

    @if (Model.Sucesso)
    {
        <div class="alert alert-success mt-4">
            <strong>Evento '@Model.NovoEvento.Titulo' cadastrado com sucesso!</strong>
            Verifique o console (terminal) da sua aplicação para ver o log gerado pelo Delegate.
        </div>
    }
</div>